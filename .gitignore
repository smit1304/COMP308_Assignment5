# =======================================================
# 1. DEPENDENCIES (Applies to both backend and frontend)
# =======================================================
node_modules/
.pnp
.pnp.js

# =======================================================
# 2. ENVIRONMENT VARIABLES & SECRETS
# =======================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# =======================================================
# 3. FRONTEND (Vite / React)
# =======================================================
frontend/dist/
frontend/dist-ssr/
frontend/*.local
frontend/.eslintcache
# Vite logs
frontend/vite.config.js.timestamp-*
frontend/vite.config.ts.timestamp-*

# =======================================================
# 4. BACKEND (Node.js / Express)
# =======================================================
backend/logs/
backend/*.log
backend/npm-debug.log*
backend/yarn-debug.log*
backend/yarn-error.log*
backend/pids/
backend/*.pid
backend/*.seed
backend/*.pid.lock
# Coverage output
backend/coverage/
backend/.nyc_output/

